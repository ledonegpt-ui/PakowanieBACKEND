    // ─── STATIONS PAGE ────────────────────────────────────────────────────────
    function StationsPage({ toast }) {
      const [stations, setStations] = useState([]);
      const [loading, setLoading] = useState(false);
      const [selected, setSelected] = useState(null);
      const [orderCode, setOrderCode] = useState("");
      const [unlocking, setUnlocking] = useState(false);
      const [unlockMode, setUnlockMode] = useState("cancel");

      useEffect(() => {
        (async () => {
          setLoading(true);
          try { const d = await api.get("/stations"); setStations(d.stations || d || []); }
          catch (e) { toast(e.message, "err"); }
          finally { setLoading(false); }
        })();
      }, []);

      async function doUnlock() {
        if (!orderCode.trim()) return;
        setUnlocking(true);
        try {
          if (unlockMode === "cancel") {
            await api.post(`/packing/orders/${orderCode.trim()}/cancel`, {});
            toast(`Sesja ${orderCode} anulowana`);
          } else {
            await api.post(`/shipping/orders/${orderCode.trim()}/reprint`, {});
            toast(`Zlecono ponowny druk etykiety dla ${orderCode}`);
          }
          setOrderCode("");
        } catch (e) { toast(e.message, "err"); }
        finally { setUnlocking(false); }
      }

      const reload = async () => {
        setLoading(true);
        try { const d = await api.get("/stations"); setStations(d.stations || d || []); }
        catch (e) { toast(e.message, "err"); }
        finally { setLoading(false); }
      };

      return (
        <div className="page">
          <div className="page-header">
            <div><h1>Stanowiska</h1><p className="page-sub">Status stanowisk i odblokowanie zablokowanych sesji</p></div>
            <button className="btn btn-ghost" onClick={reload}><Icon.Refresh /> Odśwież</button>
          </div>

          <div className="stations-grid">
            {loading ? <div className="spinner" /> :
             stations.length === 0 ? <div className="muted">Brak stanowisk</div> :
             stations.map(s => (
              <div key={s.station_code}
                className={`station-card ${selected === s.station_code ? "station-selected" : ""} ${!s.is_active ? "station-inactive" : ""}`}
                onClick={() => setSelected(selected === s.station_code ? null : s.station_code)}>
                <div className="station-code">{s.station_code}</div>
                <div className="station-name">{s.station_name}</div>
                {s.printer_ip && <div className="station-printer">🖨 {s.printer_ip}{s.printer_name && <span className="muted"> · {s.printer_name}</span>}</div>}
                <div className={`station-status ${s.is_active ? "station-active" : "station-off"}`}>{s.is_active ? "● Aktywne" : "○ Nieaktywne"}</div>
              </div>
            ))}
          </div>

          <div className="panel-card" style={{ marginTop: 28 }}>
            <div className="panel-card-title"><Icon.Unlock /> Odblokowanie sesji / druk etykiety</div>
            <p style={{ color: "var(--text-muted)", fontSize: 13, marginBottom: 16 }}>
              Gdy operator nie może wydrukować etykiety lub sesja jest zablokowana.<br />
              <strong>Anuluj sesję</strong> — operator może zacząć od nowa. &nbsp;
              <strong>Ponowny druk</strong> — wysyła zlecenie ponownego druku.
            </p>
            <div className="unlock-form">
              <input className="input-inline" placeholder="Kod zamówienia (np. 1234567)" value={orderCode} onChange={e => setOrderCode(e.target.value)} onKeyDown={e => e.key === "Enter" && doUnlock()} />
              <div className="radio-group">
                <label className={`radio-label ${unlockMode === "cancel" ? "radio-active" : ""}`}>
                  <input type="radio" value="cancel" checked={unlockMode === "cancel"} onChange={() => setUnlockMode("cancel")} />Anuluj sesję
                </label>
                <label className={`radio-label ${unlockMode === "reprint" ? "radio-active" : ""}`}>
                  <input type="radio" value="reprint" checked={unlockMode === "reprint"} onChange={() => setUnlockMode("reprint")} />Ponowny druk etykiety
                </label>
              </div>
              <button className="btn btn-danger" onClick={doUnlock} disabled={unlocking || !orderCode.trim()}>
                {unlocking ? "…" : unlockMode === "cancel" ? "Anuluj sesję" : "Drukuj ponownie"}
              </button>
            </div>
          </div>
        </div>
      );
    }

