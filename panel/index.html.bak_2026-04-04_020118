<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PAKOWACZ — Panel Admina</title>
  <!-- React + Babel via CDN — zero instalacji -->
  <script crossorigin src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
  <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <style>
    body { margin: 0; padding: 0; }
    #root { min-height: 100vh; }
  </style>
</head>
<body>
  <div id="root"></div>

  <script type="text/babel">
    const { useState, useEffect, useCallback, useRef } = React;

    // ─── CONFIG ───────────────────────────────────────────────────────────────
    const API_BASE = "https://pakowanie.led-one.pl/api/v1";

    // ─── API HELPERS ──────────────────────────────────────────────────────────
    const api = {
      token: null,
      setToken(t) { this.token = t; },
      clearToken() { this.token = null; },

      async req(method, path, body = null) {
        const headers = { "Content-Type": "application/json" };
        if (this.token) headers["Authorization"] = `Bearer ${this.token}`;
        const res = await fetch(`${API_BASE}${path}`, {
          method,
          headers,
          body: body ? JSON.stringify(body) : undefined,
        });
        const json = await res.json();
        if (!res.ok || !json.ok) throw new Error(json.error || `HTTP ${res.status}`);
        return json.data ?? json;
      },
      get: (p) => api.req("GET", p),
      post: (p, b) => api.req("POST", p, b),
    };

    // ─── HOOKS ────────────────────────────────────────────────────────────────
    function useLocalStorage(key, def) {
      const [v, setV] = useState(() => {
        try { const s = localStorage.getItem(key); return s ? JSON.parse(s) : def; } catch { return def; }
      });
      const set = useCallback((x) => {
        const val = typeof x === "function" ? x(v) : x;
        setV(val);
        try { localStorage.setItem(key, JSON.stringify(val)); } catch {}
      }, [key, v]);
      return [v, set];
    }

    // ─── ICONS ────────────────────────────────────────────────────────────────
    const Icon = {
      Orders: () => <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="12" y2="16"/></svg>,
      Picking: () => <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>,
      Stats: () => <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>,
      Station: () => <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>,
      Logout: () => <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>,
      Search: () => <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>,
      Close: () => <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>,
      Edit: () => <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>,
      Refresh: () => <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>,
      Unlock: () => <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 019.9-1"/></svg>,
      ChevronRight: () => <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="9 18 15 12 9 6"/></svg>,
      Copy: () => <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>,
      Check: () => <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><polyline points="20 6 9 17 4 12"/></svg>,
      Alert: () => <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>,
    };

    // ─── STATUS HELPERS ───────────────────────────────────────────────────────
    const STATUS_MAP = {
      "10": { label: "Nowe", cls: "status-new" },
      "40": { label: "Pakowanie", cls: "status-packing" },
      "50": { label: "Spakowane", cls: "status-packed" },
      "60": { label: "Anulowane", cls: "status-cancelled" },
      open: { label: "Otwarty", cls: "status-new" },
      completed: { label: "Ukończony", cls: "status-packed" },
      abandoned: { label: "Porzucony", cls: "status-cancelled" },
      assigned: { label: "Przypisane", cls: "status-new" },
      picked: { label: "Zebrane", cls: "status-packed" },
      dropped: { label: "Odrzucone", cls: "status-cancelled" },
    };

    function StatusBadge({ status }) {
      const s = STATUS_MAP[String(status)] || { label: String(status), cls: "status-default" };
      return <span className={`badge ${s.cls}`}>{s.label}</span>;
    }

    function CarrierBadge({ carrier }) {
      const colors = {
        dpd: "#b71c1c", inpost: "#e6a817", allegro: "#ff6600",
        gls: "#0d47a1", baselinker: "#4a148c",
      };
      const bg = colors[carrier?.toLowerCase()] || "#546e7a";
      return <span className="carrier-badge" style={{ background: bg }}>{carrier || "—"}</span>;
    }

    function fmt(dateStr) {
      if (!dateStr) return "—";
      try {
        const d = new Date(dateStr);
        return d.toLocaleString("pl-PL", { day: "2-digit", month: "2-digit", year: "numeric", hour: "2-digit", minute: "2-digit" });
      } catch { return dateStr; }
    }

    function fmtDate(dateStr) {
      if (!dateStr) return "—";
      try {
        const d = new Date(dateStr);
        return d.toLocaleDateString("pl-PL", { day: "2-digit", month: "2-digit", year: "numeric" });
      } catch { return dateStr; }
    }

    // ─── TOAST ────────────────────────────────────────────────────────────────
    function Toast({ toasts }) {
      return (
        <div className="toast-stack">
          {toasts.map(t => (
            <div key={t.id} className={`toast toast-${t.type}`}>
              {t.type === "ok" ? <Icon.Check /> : <Icon.Alert />}
              <span>{t.msg}</span>
            </div>
          ))}
        </div>
      );
    }

    function useToast() {
      const [toasts, setToasts] = useState([]);
      const show = useCallback((msg, type = "ok") => {
        const id = Date.now();
        setToasts(p => [...p, { id, msg, type }]);
        setTimeout(() => setToasts(p => p.filter(t => t.id !== id)), 3500);
      }, []);
      return { toasts, show };
    }

    // ─── LOGIN ────────────────────────────────────────────────────────────────
    function LoginScreen({ onLogin }) {
      const [login, setLogin] = useState("");
      const [station, setStation] = useState("");
      const [loading, setLoading] = useState(false);
      const [err, setErr] = useState("");

      async function submit(e) {
        e.preventDefault();
        setErr(""); setLoading(true);
        try {
          const isBarcode = /^\d+$/.test(login) && login.length > 4;
          const body = isBarcode
            ? { barcode: login, station_code: station }
            : { login, station_code: station };
          const raw = await api.post("/auth/login", body);
          // odpowiedź: { module, action, status, auth: { token, user, station } }
          const auth = raw.auth || raw;
          api.setToken(auth.token);
          onLogin(auth);
        } catch (e) {
          setErr(e.message || "Błąd logowania");
        } finally { setLoading(false); }
      }

      return (
        <div className="login-wrap">
          <div className="login-card">
            <div className="login-logo">
              <div className="login-logo-mark">P</div>
              <div>
                <div className="login-title">PAKOWACZ</div>
                <div className="login-sub">Panel Administracyjny</div>
              </div>
            </div>
            <form onSubmit={submit} className="login-form">
              <label>Login lub kod kreskowy</label>
              <input value={login} onChange={e => setLogin(e.target.value)} placeholder="np. PPOMIERNY lub barcode" required autoFocus />
              <label>Kod stanowiska</label>
              <input value={station} onChange={e => setStation(e.target.value)} placeholder="np. PAK-01" required />
              {err && <div className="login-err">{err}</div>}
              <button type="submit" disabled={loading} className="btn btn-primary btn-full">
                {loading ? "Logowanie…" : "Zaloguj się"}
              </button>
            </form>
          </div>
        </div>
      );
    }

    // ─── SIDEBAR ──────────────────────────────────────────────────────────────
    const NAV_ITEMS = [
      { key: "orders", label: "Zamówienia", Icon: Icon.Orders },
      { key: "picking", label: "Picking", Icon: Icon.Picking },
      { key: "stats", label: "Statystyki", Icon: Icon.Stats },
      { key: "stations", label: "Stanowiska", Icon: Icon.Station },
    ];

    function Sidebar({ page, setPage, user, onLogout }) {
      return (
        <aside className="sidebar">
          <div className="sidebar-brand">
            <span className="sidebar-logo-mark">P</span>
            <div>
              <div className="sidebar-app">PAKOWACZ</div>
              <div className="sidebar-role">Admin Panel</div>
            </div>
          </div>
          <nav className="sidebar-nav">
            {NAV_ITEMS.map(({ key, label, Icon: I }) => (
              <button key={key} className={`nav-item ${page === key ? "nav-active" : ""}`} onClick={() => setPage(key)}>
                <I /><span>{label}</span>
              </button>
            ))}
          </nav>
          <div className="sidebar-footer">
            <div className="sidebar-user">
              <div className="avatar">{(user?.display_name || user?.login || "A").slice(0, 1).toUpperCase()}</div>
              <div>
                <div className="sidebar-user-name">{user?.display_name || user?.login || "Admin"}</div>
                <div className="sidebar-user-role">{user?.roles?.[0] || "operator"}</div>
              </div>
            </div>
            <button className="btn-ghost btn-logout" onClick={onLogout}><Icon.Logout /> Wyloguj</button>
          </div>
        </aside>
      );
    }

    // ─── ORDERS PAGE ──────────────────────────────────────────────────────────
    function OrdersPage({ toast }) {
      const [orders, setOrders] = useState([]);
      const [loading, setLoading] = useState(false);
      const [q, setQ] = useState("");
      const [status, setStatus] = useState("");
      const [carrier, setCarrier] = useState("");
      const [selected, setSelected] = useState(null);
      const debounceRef = useRef();

      const fetchOrders = useCallback(async (params = {}) => {
        setLoading(true);
        try {
          const qp = new URLSearchParams({ limit: 100, ...params }).toString();
          const data = await api.get(`/panel/orders?${qp}`);
          setOrders(data.orders || []);
        } catch (e) { toast(e.message, "err"); }
        finally { setLoading(false); }
      }, [toast]);

      useEffect(() => { fetchOrders(); }, []);

      useEffect(() => {
        clearTimeout(debounceRef.current);
        debounceRef.current = setTimeout(() => {
          fetchOrders({ q, status, carrier });
        }, 350);
      }, [q, status, carrier]);

      return (
        <div className="page">
          <div className="page-header">
            <div>
              <h1>Zamówienia</h1>
              <p className="page-sub">Wyszukiwanie, podgląd i edycja danych zamówień</p>
            </div>
            <button className="btn btn-ghost" onClick={() => fetchOrders({ q, status, carrier })}>
              <Icon.Refresh /> Odśwież
            </button>
          </div>

          <div className="filter-bar">
            <div className="search-wrap">
              <Icon.Search />
              <input className="search-input" placeholder="Szukaj: zamówienie, imię, email, miasto, tracking…" value={q} onChange={e => setQ(e.target.value)} />
            </div>
            <select className="select" value={status} onChange={e => setStatus(e.target.value)}>
              <option value="">Wszystkie statusy</option>
              <option value="10">Nowe</option>
              <option value="40">Pakowanie</option>
              <option value="50">Spakowane</option>
              <option value="60">Anulowane</option>
            </select>
            <select className="select" value={carrier} onChange={e => setCarrier(e.target.value)}>
              <option value="">Wszyscy kurierzy</option>
              <option value="dpd">DPD</option>
              <option value="inpost">InPost</option>
              <option value="allegro">Allegro</option>
              <option value="gls">GLS</option>
            </select>
            <div className="filter-count">{loading ? "…" : `${orders.length} wyników`}</div>
          </div>

          <div className="table-wrap">
            <table className="table">
              <thead>
                <tr>
                  <th>Zamówienie</th><th>Nabywca</th><th>Miasto</th><th>Kurier</th>
                  <th>Status</th><th>Tracking</th><th>Import</th><th></th>
                </tr>
              </thead>
              <tbody>
                {loading && orders.length === 0 ? (
                  <tr><td colSpan={8} className="td-empty"><div className="spinner" /></td></tr>
                ) : orders.length === 0 ? (
                  <tr><td colSpan={8} className="td-empty">Brak wyników</td></tr>
                ) : orders.map(o => (
                  <tr key={o.order_code} className="tr-link" onClick={() => setSelected(o.order_code)}>
                    <td><code className="code">{o.order_code}</code></td>
                    <td>
                      <div className="td-main">{o.buyer_name || "—"}</div>
                      {o.email && <div className="td-sub">{o.email}</div>}
                    </td>
                    <td>{o.city || "—"}</td>
                    <td><CarrierBadge carrier={o.carrier_key} /></td>
                    <td><StatusBadge status={o.status} /></td>
                    <td>
                      {o.tracking_number || o.nr_nadania
                        ? <code className="code code-sm">{o.tracking_number || o.nr_nadania}</code>
                        : <span className="muted">—</span>}
                    </td>
                    <td className="td-date">{fmtDate(o.imported_at)}</td>
                    <td className="td-action"><Icon.ChevronRight /></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {selected && <OrderDetailModal orderCode={selected} onClose={() => setSelected(null)} toast={toast} />}
        </div>
      );
    }

    // ─── ORDER DETAIL MODAL ───────────────────────────────────────────────────
    function OrderDetailModal({ orderCode, onClose, toast }) {
      const [data, setData] = useState(null);
      const [loading, setLoading] = useState(true);
      const [editing, setEditing] = useState(false);
      const [saving, setSaving] = useState(false);
      const [form, setForm] = useState({});
      const [copied, setCopied] = useState(false);

      useEffect(() => {
        (async () => {
          setLoading(true);
          try {
            const d = await api.get(`/panel/orders/${orderCode}`);
            setData(d.order);
            const h = d.order?.header || {};
            setForm({
              delivery_fullname: h.delivery_fullname || "",
              delivery_address: h.delivery_address || "",
              delivery_city: h.delivery_city || "",
              delivery_postcode: h.delivery_postcode || "",
              phone: h.phone || "",
              email: h.email || "",
            });
          } catch (e) { toast(e.message, "err"); onClose(); }
          finally { setLoading(false); }
        })();
      }, [orderCode]);

      async function save() {
        setSaving(true);
        try {
          await api.post(`/panel/orders/${orderCode}/update`, form);
          const d = await api.get(`/panel/orders/${orderCode}`);
          setData(d.order);
          setEditing(false);
          toast("Dane zaktualizowane");
        } catch (e) { toast(e.message, "err"); }
        finally { setSaving(false); }
      }

      function copyCode() {
        navigator.clipboard?.writeText(orderCode);
        setCopied(true);
        setTimeout(() => setCopied(false), 1500);
      }

      const h = data?.header || {};

      return (
        <div className="modal-overlay" onClick={e => e.target === e.currentTarget && onClose()}>
          <div className="modal">
            <div className="modal-header">
              <div className="modal-title-wrap">
                <div className="modal-title">
                  <code className="code">{orderCode}</code>
                  <button className="btn-icon" onClick={copyCode}>{copied ? <Icon.Check /> : <Icon.Copy />}</button>
                </div>
                {data && <StatusBadge status={h.status} />}
              </div>
              <button className="btn-icon" onClick={onClose}><Icon.Close /></button>
            </div>

            {loading ? (
              <div className="modal-loading"><div className="spinner" /></div>
            ) : (
              <div className="modal-body">
                <div className="modal-cols">
                  <div>
                    <div className="section-title">
                      Dane dostawy
                      {!editing && (
                        <button className="btn btn-ghost btn-xs" onClick={() => setEditing(true)}><Icon.Edit /> Edytuj</button>
                      )}
                    </div>
                    {editing ? (
                      <div className="edit-form">
                        {[
                          ["Imię i nazwisko", "delivery_fullname"],
                          ["Adres", "delivery_address"],
                          ["Miasto", "delivery_city"],
                          ["Kod pocztowy", "delivery_postcode"],
                          ["Telefon", "phone"],
                          ["Email", "email"],
                        ].map(([label, key]) => (
                          <label key={key}>
                            <span>{label}</span>
                            <input value={form[key]} onChange={e => setForm(f => ({ ...f, [key]: e.target.value }))} />
                          </label>
                        ))}
                        <div className="edit-actions">
                          <button className="btn btn-primary" onClick={save} disabled={saving}>{saving ? "Zapisywanie…" : "Zapisz zmiany"}</button>
                          <button className="btn btn-ghost" onClick={() => setEditing(false)}>Anuluj</button>
                        </div>
                      </div>
                    ) : (
                      <div className="info-block">
                        <InfoRow label="Imię i nazwisko" value={h.delivery_fullname} />
                        <InfoRow label="Adres" value={h.delivery_address} />
                        <InfoRow label="Miasto" value={`${h.delivery_city || ""}${h.delivery_postcode ? " " + h.delivery_postcode : ""}`} />
                        <InfoRow label="Telefon" value={h.phone} />
                        <InfoRow label="Email" value={h.email} />
                      </div>
                    )}

                    <div className="section-title" style={{ marginTop: 20 }}>Zamówienie</div>
                    <div className="info-block">
                      <InfoRow label="Metoda dostawy" value={h.delivery_method} />
                      <InfoRow label="Kurier" value={<CarrierBadge carrier={data?.carrier_key} />} />
                      <InfoRow label="Tracking" value={<code className="code">{h.tracking_number || h.nr_nadania || "—"}</code>} />
                      <InfoRow label="Nr Subiekt" value={h.subiekt_doc_no} />
                      <InfoRow label="Płatność" value={h.payment_done ? "Opłacone" : "Nieopłacone"} />
                      {h.cod_amount > 0 && <InfoRow label="Pobranie" value={`${h.cod_amount} ${h.cod_currency}`} />}
                    </div>
                  </div>

                  <div>
                    <div className="section-title">Pozycje ({data?.items?.length || 0})</div>
                    <div className="items-list">
                      {(data?.items || []).map(item => (
                        <div key={item.item_id} className="item-row">
                          <div className="item-name">{item.name || item.subiekt_desc || "—"}</div>
                          <div className="item-meta">
                            {item.sku && <code className="code code-sm">{item.sku}</code>}
                            {item.subiekt_symbol && <code className="code code-sm">{item.subiekt_symbol}</code>}
                          </div>
                          <div className="item-qty">×{item.quantity}</div>
                        </div>
                      ))}
                    </div>

                    {data?.batch && (
                      <>
                        <div className="section-title" style={{ marginTop: 16 }}>Batch pickingu</div>
                        <div className="info-block">
                          <InfoRow label="Batch" value={<code className="code">{data.batch.batch_code}</code>} />
                          <InfoRow label="Status batcha" value={<StatusBadge status={data.batch.batch_status} />} />
                          <InfoRow label="Status zamówienia" value={<StatusBadge status={data.batch.order_status} />} />
                          {data.batch.drop_reason && <InfoRow label="Powód odrzucenia" value={data.batch.drop_reason} />}
                        </div>
                      </>
                    )}

                    {(data?.admin_changes || []).length > 0 && (
                      <>
                        <div className="section-title" style={{ marginTop: 16 }}>Historia zmian</div>
                        <div className="changes-list">
                          {data.admin_changes.map(c => (
                            <div key={c.id} className="change-row">
                              <div className="change-field">{c.field_name}</div>
                              <div className="change-vals">
                                <span className="change-old">{c.old_value || "—"}</span>
                                <span className="change-arrow">→</span>
                                <span className="change-new">{c.new_value}</span>
                              </div>
                              <div className="change-meta">{c.display_name || c.login} · {fmtDate(c.created_at)}</div>
                            </div>
                          ))}
                        </div>
                      </>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      );
    }

    function InfoRow({ label, value }) {
      return (
        <div className="info-row">
          <span className="info-label">{label}</span>
          <span className="info-value">{value || <span className="muted">—</span>}</span>
        </div>
      );
    }

    // ─── PICKING PAGE ─────────────────────────────────────────────────────────
    function PickingPage({ toast }) {
      const [batches, setBatches] = useState([]);
      const [loading, setLoading] = useState(false);
      const [statusFilter, setStatusFilter] = useState("");
      const [carrierFilter, setCarrierFilter] = useState("");
      const [detail, setDetail] = useState(null);
      const [detailLoading, setDetailLoading] = useState(false);

      const MODE_LABELS = { cutoff_cluster: "Dobieranie", cutoff: "Kolejka", emergency_single: "Awaryjny" };

      const fetchBatches = useCallback(async (params = {}) => {
        setLoading(true);
        try {
          const qp = new URLSearchParams({ limit: 100, ...params }).toString();
          const d = await api.get(`/admin/batches?${qp}`);
          setBatches(d.batches || []);
        } catch (e) { toast(e.message, "err"); }
        finally { setLoading(false); }
      }, [toast]);

      useEffect(() => { fetchBatches(); }, []);

      useEffect(() => {
        fetchBatches({ status: statusFilter, carrier: carrierFilter });
      }, [statusFilter, carrierFilter]);

      async function loadDetail(id) {
        setDetailLoading(true);
        try {
          const d = await api.get(`/picking/batches/${id}`);
          setDetail(d.batch || d);
        } catch (e) { toast(e.message, "err"); }
        finally { setDetailLoading(false); }
      }

      return (
        <div className="page">
          <div className="page-header">
            <div>
              <h1>Picking — Batche</h1>
              <p className="page-sub">Podgląd aktywnych i historycznych batchów zbierania</p>
            </div>
            <button className="btn btn-ghost" onClick={() => fetchBatches({ status: statusFilter, carrier: carrierFilter })}>
              <Icon.Refresh /> Odśwież
            </button>
          </div>

          <div className="filter-bar">
            <select className="select" value={statusFilter} onChange={e => setStatusFilter(e.target.value)}>
              <option value="">Wszystkie statusy</option>
              <option value="open">Otwarte</option>
              <option value="completed">Ukończone</option>
              <option value="abandoned">Porzucone</option>
            </select>
            <select className="select" value={carrierFilter} onChange={e => setCarrierFilter(e.target.value)}>
              <option value="">Wszyscy kurierzy</option>
              <option value="dpd">DPD</option>
              <option value="inpost">InPost</option>
              <option value="allegro">Allegro</option>
              <option value="gls">GLS</option>
            </select>
            <div className="filter-count">{loading ? "…" : `${batches.length} batchów`}</div>
          </div>

          <div className="table-wrap">
            <table className="table">
              <thead>
                <tr><th>Batch</th><th>Operator</th><th>Stanowisko</th><th>Kurier</th><th>Tryb</th><th>Postęp</th><th>Status</th><th>Start</th><th></th></tr>
              </thead>
              <tbody>
                {loading && batches.length === 0 ? (
                  <tr><td colSpan={9} className="td-empty"><div className="spinner" /></td></tr>
                ) : batches.length === 0 ? (
                  <tr><td colSpan={9} className="td-empty">Brak batchów</td></tr>
                ) : batches.map(b => {
                  const total = parseInt(b.total_orders) || parseInt(b.target_orders_count) || 1;
                  const picked = parseInt(b.picked_orders) || 0;
                  const pct = Math.min(100, Math.round((picked / total) * 100));
                  return (
                    <tr key={b.id} className="tr-link" onClick={() => loadDetail(b.id)}>
                      <td><code className="code">{b.batch_code}</code></td>
                      <td>
                        <div className="td-main">{b.user_name || b.user_login || "—"}</div>
                      </td>
                      <td><span className="pill-neutral">{b.station_code || "—"}</span></td>
                      <td><CarrierBadge carrier={b.carrier_key} /></td>
                      <td><span className="pill-neutral">{MODE_LABELS[b.selection_mode] || b.selection_mode || "—"}</span></td>
                      <td>
                        <div className="progress-wrap">
                          <div className="progress-bar"><div className="progress-fill" style={{ width: `${pct}%` }} /></div>
                          <span className="progress-label">{picked}/{total}</span>
                        </div>
                      </td>
                      <td><StatusBadge status={b.status} /></td>
                      <td className="td-date">{fmt(b.started_at)}</td>
                      <td className="td-action"><Icon.ChevronRight /></td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          {detail && (
            <div className="panel-card" style={{ marginTop: 20 }}>
              <div className="panel-card-title" style={{ justifyContent: "space-between" }}>
                Szczegół batcha
                <button className="btn-icon" onClick={() => setDetail(null)}><Icon.Close /></button>
              </div>
              {detailLoading ? <div className="spinner" /> : (
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8 }}>
                  <InfoRow label="ID" value={detail.id} />
                  <InfoRow label="Kod" value={<code className="code">{detail.batch_code}</code>} />
                  <InfoRow label="Status" value={<StatusBadge status={detail.status} />} />
                  <InfoRow label="Kurier" value={<CarrierBadge carrier={detail.carrier_key} />} />
                  <InfoRow label="Tryb doboru" value={MODE_LABELS[detail.selection_mode] || detail.selection_mode} />
                  <InfoRow label="Zamówień aktywnych" value={detail.active_orders_count} />
                  <InfoRow label="Start" value={fmt(detail.started_at)} />
                  <InfoRow label="Koniec" value={fmt(detail.completed_at || detail.abandoned_at)} />
                </div>
              )}
            </div>
          )}
        </div>
      );
    }

    // ─── STATS PAGE ───────────────────────────────────────────────────────────
    function StatsPage({ toast }) {
      const [tab, setTab] = useState("overview");
      const [days, setDays] = useState(7);
      const [overview, setOverview] = useState(null);
      const [daily, setDaily] = useState({ packing: [], picking: [], hourly: [] });
      const [packers, setPackers] = useState([]);
      const [carriers, setCarriers] = useState([]);
      const [userDetail, setUserDetail] = useState(null);
      const [userDetailUser, setUserDetailUser] = useState(null);
      const [loading, setLoading] = useState(true);

      useEffect(() => {
        (async () => {
          setLoading(true);
          try {
            const [ov, dl, pk, ca] = await Promise.all([
              api.get("/admin/stats/overview"),
              api.get(`/admin/stats/daily?days=${days}`),
              api.get(`/admin/stats/packers?days=${days}`),
              api.get(`/admin/stats/carriers?days=${days}`),
            ]);
            setOverview(ov.stats || ov);
            setDaily({
              packing: (dl.packing || []).slice().reverse(),
              picking: (dl.picking || []).slice().reverse(),
              hourly:  dl.hourly  || [],
            });
            setPackers(pk.packers || []);
            setCarriers(ca.carriers || []);
          } catch (e) { toast(e.message, "err"); }
          finally { setLoading(false); }
        })();
      }, [days]);

      async function loadUserDetail(user) {
        setUserDetailUser(user);
        setUserDetail(null);
        try {
          const d = await api.get(`/admin/stats/users/${user.user_id}/daily?days=${days}`);
          setUserDetail(d.daily || []);
        } catch (e) { toast(e.message, "err"); }
      }

      const packedToday = overview?.packed_today ?? 0;
      const packedYesterday = overview?.packed_yesterday ?? 0;
      const pctVsYesterday = packedYesterday > 0
        ? Math.round(((packedToday - packedYesterday) / packedYesterday) * 100) : null;

      const maxPacked = daily.packing.length ? Math.max(...daily.packing.map(d => d.packed_count), 1) : 1;
      const maxHourly = daily.hourly.length ? Math.max(...daily.hourly.map(d => d.packed_count), 1) : 1;
      const maxPackerPacked = packers.length ? packers[0]?.packed_count || 1 : 1;
      const totalCarrierPacked = carriers.reduce((s, c) => s + (c.packed || 0), 0) || 1;

      const TABS = [
        { key: "overview", label: "Przegląd" },
        { key: "packers",  label: "Pakerzy" },
        { key: "carriers", label: "Kurierzy" },
        { key: "daily",    label: "Dzienny" },
      ];

      return (
        <div className="page">
          <div className="page-header">
            <div><h1>Statystyki</h1><p className="page-sub">Wydajność pakerów, kurierzy, wolumeny</p></div>
            <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
              <span style={{ fontSize: 12, color: "var(--text-muted)" }}>Zakres:</span>
              {[7, 14, 30, 90].map(d => (
                <button key={d} className={`btn ${days === d ? "btn-primary" : "btn-ghost"} btn-xs`} onClick={() => setDays(d)}>{d}d</button>
              ))}
            </div>
          </div>

          {/* Tabs */}
          <div className="tabs-bar">
            {TABS.map(t => (
              <button key={t.key} className={`tab-btn ${tab === t.key ? "tab-active" : ""}`} onClick={() => setTab(t.key)}>
                {t.label}
              </button>
            ))}
          </div>

          {loading ? (
            <div style={{ display: "flex", justifyContent: "center", padding: 60 }}><div className="spinner" /></div>
          ) : (
            <>
              {/* ── OVERVIEW TAB ── */}
              {tab === "overview" && (
                <>
                  <div className="kpi-grid">
                    <div className="kpi-card kpi-green">
                      <div className="kpi-value">{packedToday}</div>
                      <div className="kpi-label">Spakowane dziś</div>
                      <div className="kpi-sub">
                        {pctVsYesterday !== null
                          ? `${pctVsYesterday >= 0 ? "↑ +" : "↓ "}${pctVsYesterday}% vs wczoraj (${packedYesterday})`
                          : `wczoraj: ${packedYesterday}`}
                      </div>
                    </div>
                    <div className="kpi-card kpi-blue">
                      <div className="kpi-value">{overview?.active_packing_sessions ?? "—"}</div>
                      <div className="kpi-label">Aktywne sesje</div>
                      <div className="kpi-sub">pakowanie teraz</div>
                    </div>
                    <div className="kpi-card kpi-blue" style={{ borderLeftColor: "#7c3aed" }}>
                      <div className="kpi-value">{overview?.open_batches ?? "—"}</div>
                      <div className="kpi-label">Otwarte batche</div>
                      <div className="kpi-sub">picking w toku</div>
                    </div>
                    <div className="kpi-card kpi-amber">
                      <div className="kpi-value">{overview?.new_orders ?? "—"}</div>
                      <div className="kpi-label">Nowe zamówienia</div>
                      <div className="kpi-sub">oczekują na picking</div>
                    </div>
                    <div className="kpi-card kpi-amber" style={{ borderLeftColor: "#b45309" }}>
                      <div className="kpi-value">{overview?.packing_orders ?? "—"}</div>
                      <div className="kpi-label">W pakowaniu</div>
                      <div className="kpi-sub">status 40</div>
                    </div>
                    <div className="kpi-card kpi-red">
                      <div className="kpi-value">{overview?.cancelled_7d ?? "—"}</div>
                      <div className="kpi-label">Anulowane (7 dni)</div>
                      <div className="kpi-sub">wymagają uwagi</div>
                    </div>
                    <div className="kpi-card kpi-green" style={{ borderLeftColor: "#0891b2" }}>
                      <div className="kpi-value">{overview?.total_orders ?? "—"}</div>
                      <div className="kpi-label">Zamówień łącznie</div>
                      <div className="kpi-sub">wszystkie statusy</div>
                    </div>
                    <div className="kpi-card" style={{ borderLeft: "4px solid #6b7280" }}>
                      <div className="kpi-value" style={{ fontSize: 24 }}>{
                        overview?.total_orders > 0
                          ? Math.round((((overview?.packed_today ?? 0) * 100) / (overview?.total_orders ?? 1))) + "%"
                          : "—"
                      }</div>
                      <div className="kpi-label">Wypełnienie dziś</div>
                      <div className="kpi-sub">spakowane / wszystkie</div>
                    </div>
                  </div>

                  {/* Hourly heatmap */}
                  <div className="panel-card">
                    <div className="panel-card-title">Heatmapa godzinowa — kiedy pakujemy ({days} dni)</div>
                    <div className="hourly-grid">
                      {daily.hourly.map(h => {
                        const intensity = maxHourly > 0 ? h.packed_count / maxHourly : 0;
                        const bg = intensity === 0
                          ? "#F1F5F9"
                          : `rgba(59, 114, 203, ${Math.max(0.08, intensity)})`;
                        return (
                          <div key={h.hour} className="hourly-cell" style={{ background: bg }} title={`${h.hour}:00 — ${h.packed_count} paczek`}>
                            <div className="hourly-hour">{h.hour}:00</div>
                            <div className="hourly-count">{h.packed_count || ""}</div>
                          </div>
                        );
                      })}
                    </div>
                  </div>

                  {/* Daily chart */}
                  <div className="panel-card">
                    <div className="panel-card-title">Dzienna liczba spakowanych ({days} dni)</div>
                    {daily.packing.length === 0 ? (
                      <div className="muted" style={{ padding: "16px 0", fontSize: 13 }}>Brak danych w wybranym okresie</div>
                    ) : (
                      <div className="bar-chart">
                        {daily.packing.map(d => (
                          <div key={d.day} className="bar-group">
                            <div className="bar-col">
                              <div className="bar-tooltip">{d.packed_count}</div>
                              <div className="bar bar-packed" style={{ height: `${Math.max(4, Math.round((d.packed_count / maxPacked) * 120))}px` }} />
                            </div>
                            <div className="bar-label">{d.day ? d.day.slice(5).replace("-", ".") : ""}</div>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </>
              )}

              {/* ── PACKERS TAB ── */}
              {tab === "packers" && (
                <>
                  <div className="panel-card">
                    <div className="panel-card-title">Wydajność pakerów — ostatnie {days} dni</div>
                    {packers.length === 0 ? (
                      <div className="muted" style={{ padding: "12px 0", fontSize: 13 }}>Brak danych</div>
                    ) : (
                      <table className="table">
                        <thead>
                          <tr>
                            <th>#</th><th>Paker</th>
                            <th title="Ukończone sesje pakowania">📦 Spakowane</th>
                            <th title="Anulowane sesje">❌ Anulowane</th>
                            <th title="Średni czas sesji pakowania">⏱ Śr. pakowanie</th>
                            <th title="Najszybsza sesja">⚡ Min</th>
                            <th title="Najwolniejsza sesja">🐢 Max</th>
                            <th title="Łączny czas pakowania w godzinach">🕐 Razem (h)</th>
                            <th title="Ukończone batche pickingu">🗂 Batche</th>
                            <th title="Zamówienia zebrane w pickingu">✅ Zebrane</th>
                            <th title="Zamówienia odrzucone w pickingu">⬇ Odrzucone</th>
                            <th title="Średni czas batcha pickingu">⏱ Śr. picking</th>
                            <th>Wydajność</th>
                          </tr>
                        </thead>
                        <tbody>
                          {packers.map((p, i) => {
                            const pct = Math.round((p.packed_count / maxPackerPacked) * 100);
                            return (
                              <tr key={p.user_id} className="tr-link" onClick={() => { setUserDetailUser(p); loadUserDetail(p); setTab("userdetail"); }}>
                                <td className="muted">{i + 1}</td>
                                <td>
                                  <div className="td-main">{p.display_name || p.login}</div>
                                  <div className="td-sub">{p.login}</div>
                                </td>
                                <td><strong>{p.packed_count}</strong></td>
                                <td>{p.cancelled_count > 0 ? <span style={{ color: "var(--red)" }}>{p.cancelled_count}</span> : <span className="muted">0</span>}</td>
                                <td><code className="code">{p.avg_pack_label || "—"}</code></td>
                                <td><span style={{ color: "var(--green)", fontSize: 12 }}>{p.min_pack_label || "—"}</span></td>
                                <td><span style={{ color: "var(--text-muted)", fontSize: 12 }}>{p.max_pack_label || "—"}</span></td>
                                <td><code className="code">{p.total_pack_hours != null ? p.total_pack_hours + "h" : "—"}</code></td>
                                <td>{p.batches_count}</td>
                                <td>{p.picked_orders}</td>
                                <td>{p.dropped_orders > 0 ? <span style={{ color: "var(--amber)" }}>{p.dropped_orders}</span> : <span className="muted">0</span>}</td>
                                <td><code className="code">{p.avg_batch_label || "—"}</code></td>
                                <td style={{ minWidth: 140 }}>
                                  <div className="progress-wrap">
                                    <div className="progress-bar"><div className="progress-fill" style={{ width: `${pct}%` }} /></div>
                                    <span className="progress-label">{pct}%</span>
                                  </div>
                                </td>
                              </tr>
                            );
                          })}
                        </tbody>
                      </table>
                    )}
                    <div className="muted" style={{ fontSize: 11, marginTop: 10 }}>Kliknij w pakera aby zobaczyć dzienny breakdown →</div>
                  </div>
                </>
              )}

              {/* ── USER DETAIL TAB ── */}
              {tab === "userdetail" && (
                <div className="panel-card">
                  <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 16 }}>
                    <button className="btn btn-ghost btn-xs" onClick={() => setTab("packers")}>← Wróć</button>
                    <div className="panel-card-title" style={{ margin: 0 }}>
                      {userDetailUser?.display_name || userDetailUser?.login} — dzienny breakdown ({days} dni)
                    </div>
                  </div>
                  {userDetail === null ? (
                    <div className="spinner" />
                  ) : userDetail.length === 0 ? (
                    <div className="muted" style={{ fontSize: 13 }}>Brak danych w wybranym okresie</div>
                  ) : (
                    <table className="table">
                      <thead>
                        <tr><th>Dzień</th><th>Spakowane</th><th>Śr. czas pakowania</th><th>Łącznie (h)</th><th>Batche</th><th>Zebrane</th><th>Odrzucone</th></tr>
                      </thead>
                      <tbody>
                        {userDetail.map(d => (
                          <tr key={d.day}>
                            <td><strong>{d.day}</strong></td>
                            <td>{d.packed_count}</td>
                            <td><code className="code">{d.avg_pack_label || "—"}</code></td>
                            <td>{d.total_pack_hours != null ? d.total_pack_hours + "h" : "—"}</td>
                            <td>{d.batches_count}</td>
                            <td>{d.picked_orders}</td>
                            <td>{d.dropped_orders > 0 ? <span style={{ color: "var(--amber)" }}>{d.dropped_orders}</span> : 0}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  )}
                </div>
              )}

              {/* ── CARRIERS TAB ── */}
              {tab === "carriers" && (
                <>
                  <div className="kpi-grid" style={{ gridTemplateColumns: "repeat(auto-fill, minmax(200px, 1fr))" }}>
                    {carriers.map(c => {
                      const pendingTotal = (c.new || 0) + (c.packing || 0);
                      return (
                        <div key={c.carrier_key} className="kpi-card" style={{ borderLeft: "4px solid var(--blue)" }}>
                          <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 10 }}>
                            <CarrierBadge carrier={c.carrier_key} />
                          </div>
                          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "4px 12px", fontSize: 12 }}>
                            <span className="muted">Spakowane</span><strong style={{ color: "var(--green)" }}>{c.packed}</strong>
                            <span className="muted">Nowe</span><strong style={{ color: "var(--blue)" }}>{c.new}</strong>
                            <span className="muted">W pakowaniu</span><strong style={{ color: "var(--amber)" }}>{c.packing}</strong>
                            <span className="muted">Anulowane</span><strong style={{ color: c.cancelled > 0 ? "var(--red)" : "var(--text-muted)" }}>{c.cancelled}</strong>
                            <span className="muted">Razem</span><strong>{c.total}</strong>
                            <span className="muted">Do zrobienia</span><strong style={{ color: pendingTotal > 0 ? "var(--amber)" : "var(--text-muted)" }}>{pendingTotal}</strong>
                          </div>
                        </div>
                      );
                    })}
                  </div>

                  <div className="panel-card">
                    <div className="panel-card-title">Rozkład zamówień wg kuriera — wszystkie statusy</div>
                    <table className="table">
                      <thead>
                        <tr><th>Kurier</th><th>Spakowane</th><th>Nowe (kolejka)</th><th>W pakowaniu</th><th>Anulowane</th><th>Razem</th><th>% z całości</th></tr>
                      </thead>
                      <tbody>
                        {carriers.map(c => {
                          const totalAll = carriers.reduce((s, x) => s + x.total, 0) || 1;
                          const pct = Math.round((c.total / totalAll) * 100);
                          return (
                            <tr key={c.carrier_key}>
                              <td><CarrierBadge carrier={c.carrier_key} /></td>
                              <td><span style={{ color: "var(--green)", fontWeight: 600 }}>{c.packed}</span></td>
                              <td>{c.new}</td>
                              <td>{c.packing}</td>
                              <td>{c.cancelled > 0 ? <span style={{ color: "var(--red)" }}>{c.cancelled}</span> : 0}</td>
                              <td><strong>{c.total}</strong></td>
                              <td>
                                <div className="progress-wrap">
                                  <div className="progress-bar"><div className="progress-fill" style={{ width: `${pct}%` }} /></div>
                                  <span className="progress-label">{pct}%</span>
                                </div>
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                </>
              )}

              {/* ── DAILY TAB ── */}
              {tab === "daily" && (
                <>
                  <div className="panel-card">
                    <div className="panel-card-title">Pakowanie — dzień po dniu ({days} dni)</div>
                    <table className="table">
                      <thead>
                        <tr><th>Dzień</th><th>Spakowane</th><th>Śr. czas pakowania</th><th>Min / Max</th><th>Unikalnych pakerów</th><th>Anulowane sesje</th></tr>
                      </thead>
                      <tbody>
                        {daily.packing.slice().reverse().map(d => (
                          <tr key={d.day}>
                            <td><strong>{d.day}</strong></td>
                            <td>{d.packed_count}</td>
                            <td><code className="code">{d.avg_pack_seconds != null ? Math.floor(d.avg_pack_seconds/60)+"m "+String(d.avg_pack_seconds%60).padStart(2,"0")+"s" : "—"}</code></td>
                            <td style={{ fontSize: 12 }}>
                              <span style={{ color: "var(--green)" }}>{d.min_pack_seconds != null ? Math.floor(d.min_pack_seconds/60)+"m "+String(d.min_pack_seconds%60).padStart(2,"0")+"s" : "—"}</span>
                              {" / "}
                              <span className="muted">{d.max_pack_seconds != null ? Math.floor(d.max_pack_seconds/60)+"m "+String(d.max_pack_seconds%60).padStart(2,"0")+"s" : "—"}</span>
                            </td>
                            <td>{d.unique_packers}</td>
                            <td>{d.cancelled_sessions > 0 ? <span style={{ color: "var(--red)" }}>{d.cancelled_sessions}</span> : <span className="muted">0</span>}</td>
                          </tr>
                        ))}
                      </tbody>
