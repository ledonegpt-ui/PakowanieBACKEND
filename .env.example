MYSQL_DB=admin_pakowanie
MYSQL_USER=admin_konrad
MYSQL_PASS=889konrad889
MYSQL_CHARSET=utf8mb4

# (opcjonalnie) MYSQL - Twoja stara baza admin_automat (jeśli będziesz brał fotki/tytuły itp.)
