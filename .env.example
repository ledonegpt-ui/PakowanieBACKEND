MYSQL2_DB=admin_automat
MYSQL2_USER=admin_konrad
MYSQL2_PASS=889konrad889
MYSQL2_CHARSET=utf8mb4

# FIREBIRD (EazyUploader)
# Uwaga na backslash w ścieżkach - użyj podwójnych \\ lub cudzysłowów
